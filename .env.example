# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Ahi AI
NEXT_PUBLIC_APP_URL=https://www.aiahi.net

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_STT_MODEL=whisper-1

# --- WhatsApp (Meta Cloud API) ---
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_WEBHOOK_SECRET=your-webhook-secret
WHATSAPP_STRICT_SIGNATURE=false
WHATSAPP_API_PHONE=905551234567
WHATSAPP_REMINDER_TEMPLATE_NAME=
WHATSAPP_CAMPAIGN_TEMPLATE_NAME=
WHATSAPP_RESUME_TEMPLATE_NAME=continue_chat_tr
WHATSAPP_TEMPLATE_LANG=tr

# --- Redis (Upstash) ---
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token
MEDIA_ENCRYPTION_KEY=64-hex-or-base64-32-byte-key

# --- Inngest (Vercel timeout kurtarıcı: webhook mesajı kuyruğa atar, 200 OK döner, arka planda işlenir) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Sentry (Production hata takibi) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- PostHog (Ürün analitiği: sayfa görüntüleme, funnel, kullanıcı davranışı) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Langfuse (LLM gözlemcisi: token maliyeti, tenant bazlı kullanım, hata takibi) ---
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Admin auth ---
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=change-this-admin-session-secret-at-least-32-chars
ADMIN_HIDDEN_LOGIN_IDENTIFIER=nuronuro458@gmail.com

# --- Contact form (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxx
# İletişim formundan gelen mesajların gönderileceği e-posta (boşsa ADMIN_HIDDEN_LOGIN_IDENTIFIER kullanılır)
CONTACT_EMAIL=

# --- Cron ---
CRON_SECRET=change-this-cron-secret

# --- Feature flags ---
ENABLE_DASHBOARD_V2=true
ENABLE_CRM_MODULE=true
# Twilio Verify anahtarları doğru girildikten sonra true yapın.
ENABLE_SMS_2FA=false
ENABLE_INFO_SMS=false
INFO_SMS_MODE=fallback

# --- Twilio Verify (SMS OTP) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_SMS_FROM_E164=+12494990938
ADMIN_2FA_PHONE_E164=+905551112233
